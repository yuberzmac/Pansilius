<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pansilius | Panel de Administración</title>
    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="stylesheet" href="menupanel.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet">
    <style>
        .nav-item .material-icons-round { font-size: 20px; }
        @media (max-width: 900px) {
            .nav-item .material-icons-round { font-size: 24px; margin-bottom: 4px; }
        }
        .system-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 1rem; }
        .tool-card { cursor: pointer; transition: all 0.3s ease; border: 1px solid var(--border); position: relative; overflow: hidden; }
        .tool-card:hover { transform: translateY(-5px); border-color: var(--primary); box-shadow: 0 10px 25px -5px rgba(79, 70, 229, 0.1); }
        .modal-xl { width: 95% !important; max-width: 1200px !important; height: 85vh !important; }
        .modal-body-scroll { height: calc(100% - 120px); overflow-y: auto; padding-right: 10px; }
        pre.log-box { text-align: left; background: #0f172a; color: #38bdf8; padding: 1rem; border-radius: 8px; font-size: 0.75rem; max-height: 500px; overflow-y: auto; font-family: 'Courier New', monospace; white-space: pre-wrap; }
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <div class="wrapper">
        <aside class="sidebar">
            <div class="logo" onclick="toggleView('dashboard')" style="cursor: pointer;">
                <div class="logo-box" style="color: white; padding: 5px;">P</div>
                <h2 style="font-size: 1.25rem; color: white;">Pansilius</h2>
            </div>
            <div id="nav-dashboard" class="nav-item hidden" onclick="toggleView('dashboard')">
                <span class="material-icons-round">dashboard</span>
                <span>Dashboard</span>
            </div>
            <div id="nav-shop" class="nav-item" onclick="toggleView('shop')">
                <span class="material-icons-round">shopping_bag</span>
                <span>Tienda</span>
            </div>
            <div id="nav-purchases" class="nav-item" onclick="toggleView('purchases')">
                <span class="material-icons-round">history</span>
                <span>Mis Compras</span>
            </div>
            <div id="nav-users" class="nav-item hidden" onclick="toggleView('users')">
                <span class="material-icons-round">people</span>
                <span>Usuarios</span>
            </div>
            <div id="nav-system" class="nav-item hidden" onclick="toggleView('system')">
                <span class="material-icons-round">settings_remote</span>
                <span>Servidor</span>
            </div>
            <div id="nav-reports" class="nav-item hidden" onclick="toggleView('reports')">
                <span class="material-icons-round">analytics</span>
                <span>Reportes</span>
            </div>
            <div id="nav-profile" class="nav-item" onclick="toggleView('profile')">
                <span class="material-icons-round">account_circle</span>
                <span>Perfil</span>
            </div>
            <div style="margin-top: auto;" class="desktop-only">
                <div class="nav-item" onclick="logout()" style="color: #f87171;">
                    <span class="material-icons-round">logout</span>
                    <span>Cerrar Sesión</span>
                </div>
            </div>
        </aside>

        <main class="main-content">
            <!-- Dashboard View -->
            <div id="view-dashboard">
                <header class="top-bar">
                    <div>
                        <h1 style="font-size: 1.75rem;">Dashboard de Control</h1>
                        <p style="color: var(--text-gray);">Gestiona tus productos y estadísticas.</p>
                    </div>
                    <div class="user-profile">
                        <img id="user-img-small" src="" alt="" class="user-avatar" style="display:none; width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
                        <span id="user-name" style="font-weight: 600;">Usuario</span>
                        <span id="user-role-badge" class="badge badge-active" style="margin-left: 10px; font-size: 0.7rem;">User</span>
                    </div>
                </header>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-label">Total Productos</div><div id="stat-total" class="stat-val">0</div></div>
                    <div class="stat-card"><div class="stat-label">Activos</div><div id="stat-active" class="stat-val" style="color: var(--success);">0</div></div>
                    <div class="stat-card"><div class="stat-label">Inactivos</div><div id="stat-inactive" class="stat-val" style="color: var(--danger);">0</div></div>
                </div>
                <div id="admin-actions-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <h2 style="margin: 0;">Mis Productos</h2>
                    <button id="btn-add-item" onclick="showModal(true)" class="btn-add hidden">+ Añadir Producto</button>
                </div>
                <div id="product-container" class="product-grid"></div>
            </div>

            <!-- Users View -->
            <div id="view-users" class="hidden">
                <header class="top-bar"><h1 style="font-size: 1.75rem;">Gestión de Usuarios</h1></header>
                <div class="stat-card">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead><tr style="border-bottom: 2px solid var(--border);"><th>Usuario</th><th>Email</th><th>Nombre</th><th>Rol</th><th>Acciones</th></tr></thead>
                        <tbody id="users-table-body"></tbody>
                    </table>
                </div>
            </div>

            <!-- Reports View -->
            <div id="view-reports" class="hidden">
                <header class="top-bar"><h1 style="font-size: 1.75rem;">Reporte de Ventas</h1></header>
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-label">Ventas Totales</div><div id="rep-total-sales" class="stat-val">0</div></div>
                    <div class="stat-card"><div class="stat-label">Recaudación</div><div id="rep-total-earnings" class="stat-val" style="color: var(--success);">$0.00</div></div>
                </div>
                <div class="stat-card">
                    <h2 style="margin-bottom: 1.5rem;">Historial</h2>
                    <table style="width: 100%; border-collapse: collapse;"><tbody id="sales-report-body"></tbody></table>
                </div>
            </div>

            <!-- System View -->
            <div id="view-system" class="hidden">
                <header class="top-bar"><h1 style="font-size: 1.75rem;">Centro de Control</h1></header>
                <div class="system-grid">
                    <div class="stat-card tool-card">
                        <div class="stat-label">Memoria RAM</div><div id="ram-usage" class="stat-val">...</div>
                        <div style="width: 100%; background: #eee; height: 6px; border-radius: 3px;"><div id="ram-bar" style="width: 0%; background: var(--primary); height: 100%;"></div></div>
                    </div>
                    <div class="stat-card tool-card" onclick="openWindow('explorer')">
                        <div class="stat-label">Disco (Click para ver archivos)</div><div id="disk-usage" class="stat-val">...</div>
                        <div style="width: 100%; background: #eee; height: 6px; border-radius: 3px;"><div id="disk-bar" style="width: 0%; background: var(--success); height: 100%;"></div></div>
                    </div>
                    <div class="stat-card tool-card" onclick="openWindow('db')"><div class="stat-label">Base de Datos</div><div class="stat-val">📊 Ver Tablas</div></div>
                    <div class="stat-card tool-card" onclick="openWindow('terminal')"><div class="stat-label">Terminal</div><div class="stat-val">💻 Consola</div></div>
                </div>
                <div class="stat-card" style="margin-top: 2rem;">
                    <button onclick="restartServer()" class="btn-add" style="background:#ef4444; width:100%;">🔄 Reiniciar Servidor</button>
                    <button onclick="showLogs()" class="secondary" style="width:100%; margin-top:10px;">ℹ️ Ver Logs</button>
                </div>
            </div>

            <!-- Shop View -->
            <div id="view-shop" class="hidden">
                <header class="top-bar">
                    <div>
                        <h1 style="font-size: 1.75rem;">Tienda Online</h1>
                        <p style="color: var(--text-gray);">Explora nuestro catálogo exclusivo.</p>
                    </div>
                    <div style="display:flex; gap:10px;">
                        <input type="text" id="shop-search" placeholder="Buscar productos..." oninput="filterShop()" style="max-width:300px;">
                    </div>
                </header>
                <div id="shop-container" class="product-grid"></div>
            </div>

            <!-- Profile View -->
            <div id="view-profile" class="hidden">
                <header class="top-bar"><h1 style="font-size: 1.75rem;">Mi Perfil</h1></header>
                <div class="stat-card" style="max-width: 600px; margin: 0 auto;">
                    <div style="text-align: center; margin-bottom: 2rem;">
                        <img id="profile-img-preview" src="" style="width: 120px; height: 120px; border-radius: 20px; object-fit: cover; border: 4px solid var(--primary);">
                        <h2 id="profile-username-title">Usuario</h2>
                    </div>
                    <form id="profile-form">
                        <div class="form-group"><label>Email</label><input type="email" id="p-email"></div>
                        <div class="form-group"><label>Nombre</label><input type="text" id="p-nombre"></div>
                        <div class="form-group"><label>Teléfono</label><input type="text" id="p-telefono"></div>
                        <div class="form-group"><label>Nueva Pass</label><input type="password" id="p-password"></div>
                        <div class="form-group"><label>Foto</label><input type="file" id="p-foto" accept="image/*"></div>
                        <button type="button" onclick="updateProfile()" class="btn-add" style="width: 100%;">Guardar Perfil</button>
                    </form>
                </div>
            </div>

            <!-- Purchases View -->
            <div id="view-purchases" class="hidden">
                <header class="top-bar"><h1 style="font-size: 1.75rem;">Mis Compras</h1></header>
                <div class="stat-card"><table style="width: 100%; border-collapse: collapse;"><tbody id="purchases-table-body"></tbody></table></div>
            </div>
        </main>
    </div>

    <!-- Modales -->
    <div id="win-explorer" class="modal"><div class="modal-content modal-xl">
        <div style="display:flex; justify-content:space-between;"><h2>📁 Archivos</h2><button onclick="closeWindow('explorer')">&times;</button></div>
        <div style="margin: 10px 0;"><button onclick="loadSystemInfo('..')">⬅️ Volver</button> <input type="file" id="file-upload-input" onchange="uploadFileToServer()"></div>
        <div class="modal-body-scroll"><table style="width: 100%;"><tbody id="file-explorer-body"></tbody></table></div>
    </div></div>

    <div id="win-db" class="modal"><div class="modal-content" style="max-width: 500px;">
        <div style="display:flex; justify-content:space-between;"><h2>📊 Base de Datos</h2><button onclick="closeWindow('db')">&times;</button></div>
        <div id="db-tables-container"></div>
    </div></div>

    <div id="win-terminal" class="modal"><div class="modal-content modal-xl" style="background:#0c1117; color:#39d353; border: 1px solid #30363d; padding: 0; overflow: hidden; display: flex; flex-direction: column;">
        <div style="background:#161b22; padding: 10px 20px; display:flex; justify-content:space-between; align-items:center; border-bottom: 1px solid #30363d;">
            <div style="display:flex; gap:8px;">
                <div style="width:12px; height:12px; border-radius:50%; background:#ff5f56;"></div>
                <div style="width:12px; height:12px; border-radius:50%; background:#ffbd2e;"></div>
                <div style="width:12px; height:12px; border-radius:50%; background:#27c93f;"></div>
                <span style="margin-left:10px; font-size:0.8rem; color:#8b949e; font-family:monospace;">pansilius@server:~</span>
            </div>
            <button onclick="closeWindow('terminal')" style="background:transparent; color:#8b949e; font-size:1.5rem; padding:0; line-height:1;">&times;</button>
        </div>
        <div id="terminal-output" style="flex:1; overflow-y:auto; font-family:'Courier New', monospace; padding:20px; font-size:0.9rem; line-height:1.5; scroll-behavior: smooth;">
            <div><span style="color:#58a6ff;">Pansilius Web Terminal [Version 2.8.0]</span></div>
            <div>(c) 2026 Pansilius Corp. Todos los derechos reservados.</div><br>
        </div>
        <div style="padding: 10px 20px; background:#0c1117; display:flex; align-items:center; gap:10px; border-top: 1px solid #30363d;">
            <span style="color:#39d353; font-family:monospace; font-weight:bold;">$</span>
            <input type="text" id="terminal-input" style="flex:1; background:transparent; border:none; color:#fff; font-family:monospace; outline:none; font-size:0.9rem;" autofocus onkeydown="if(event.key==='Enter') executeTerminal()">
        </div>
    </div></div>

    <div id="item-modal" class="modal"><div class="modal-content">
        <h2 id="modal-title">Producto</h2>
        <div class="form-group"><label>Nombre</label><input type="text" id="i-nombre"></div>
        <div class="form-group"><label>Precio</label><input type="number" id="i-precio"></div>
        <div class="form-group"><label>Stock</label><input type="number" id="i-stock"></div>
        <div class="form-group"><label>Desc</label><input type="text" id="i-desc"></div>
        <div class="form-group"><label>Estado</label><select id="i-estado"><option value="true">Activo</option><option value="false">Inactivo</option></select></div>
        <button onclick="saveItem()" class="btn-add">Guardar</button><button onclick="showModal(false)">Cerrar</button>
    </div></div>

    <div id="editor-modal" class="modal"><div class="modal-content modal-xl">
        <h2 id="editor-filename">Editor</h2>
        <textarea id="editor-textarea" style="width:100%; height:70%; background:#1e293b; color:#fff; font-family:monospace;"></textarea>
        <button onclick="saveFileContent()" class="btn-add">Guardar Cambios</button><button onclick="closeEditor()">Cerrar</button>
    </div></div>

    <!-- Modales de RBAC -->
    <div id="win-rbac" class="modal"><div class="modal-content" style="max-width: 800px;">
        <div style="display:flex; justify-content:space-between;"><h2>🔐 Seguridad y Permisos (RBAC)</h2><button onclick="closeWindow('rbac')">&times;</button></div>
        <div style="display:grid; grid-template-columns: 1fr 2fr; gap: 20px; margin-top: 20px;">
            <div style="border-right: 1px solid #eee; padding-right: 20px;">
                <h3>Roles</h3>
                <div id="roles-list" style="display:flex; flex-direction:column; gap:10px; margin-top:10px;"></div>
                <div style="margin-top:20px;">
                    <input type="text" id="new-role-name" placeholder="Nuevo Rol" style="width:100%; margin-bottom:10px;">
                    <button onclick="createRole()" class="btn-add" style="width:100%;">+ Crear Rol</button>
                </div>
            </div>
            <div>
                <h3>Permisos para: <span id="selected-role-name" style="color:var(--primary);">Selecciona un rol</span></h3>
                <div id="permissions-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin-top:10px; max-height: 400px; overflow-y: auto;"></div>
            </div>
        </div>
    </div></div>

    <script>
        const token = localStorage.getItem('token');
        const role = localStorage.getItem('role');
        if (!token) window.location.href = '/index.html';

        window.selectedRoleId = null;

        if (role === 'admin') {
            document.querySelectorAll('.hidden').forEach(el => {
                if (el.id && (el.id.startsWith('nav-') || el.id === 'btn-add-item')) {
                    el.classList.remove('hidden');
                }
            });
            // Añadir botón de RBAC al nav de usuarios si no existe
            const usersHeader = document.querySelector('#view-users header');
            if (usersHeader && !document.getElementById('btn-open-rbac')) {
                const btn = document.createElement('button');
                btn.id = 'btn-open-rbac';
                btn.className = 'btn-add';
                btn.style.marginLeft = '20px';
                btn.textContent = '🛡️ Gestionar Roles';
                btn.onclick = () => openWindow('rbac');
                usersHeader.appendChild(btn);
            }
            document.getElementById('user-role-badge').textContent = 'Admin';
            document.getElementById('user-role-badge').className = 'badge badge-active';
        }

        function toggleView(view) {
            ['dashboard', 'shop', 'users', 'profile', 'purchases', 'system', 'reports'].forEach(v => {
                const el = document.getElementById('view-' + v); if(el) el.classList.toggle('hidden', v !== view);
                const nav = document.getElementById('nav-' + v); if(nav) nav.classList.toggle('active', v === view);
            });
            if (view === 'dashboard') loadItems();
            if (view === 'shop') loadShop();
            if (view === 'system') refreshSystemStats();
            if (view === 'users') loadUsers();
            if (view === 'reports') loadReports();
            if (view === 'profile') loadProfile(); // Asegurar que carga el perfil
            if (view === 'purchases') loadPurchases();
        }

        async function loadShop() {
            const res = await fetch(`/api/items?token=${token}`);
            const items = await res.json();
            window.allShopItems = items.filter(i => i.estado && i.stock > 0);
            renderShop(window.allShopItems);
        }

        function renderShop(items) {
            document.getElementById('shop-container').innerHTML = items.map(i => `
                <div class="product-card" style="border-top: 4px solid var(--primary);">
                    <div style="font-size: 1.2rem; font-weight: 800; color: var(--primary); margin-bottom: 5px;">${i.nombre}</div>
                    <p style="font-size: 0.85rem; color: var(--text-gray); height: 40px; overflow: hidden;">${i.descripcion}</p>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:15px;">
                        <span style="font-size: 1.5rem; font-weight: 700;">$${i.precio}</span>
                        <span style="font-size: 0.8rem; color: var(--text-gray);">Stock: ${i.stock}</span>
                    </div>
                    <button onclick="buyItem(${i.id})" class="btn-add" style="width:100%; margin-top:15px; background: linear-gradient(90deg, var(--primary), #818cf8);">🛒 Comprar Ahora</button>
                </div>
            `).join('');
        }

        function filterShop() {
            const query = document.getElementById('shop-search').value.toLowerCase();
            const filtered = window.allShopItems.filter(i => i.nombre.toLowerCase().includes(query) || i.descripcion.toLowerCase().includes(query));
            renderShop(filtered);
        }

        function openWindow(win) { 
            document.getElementById('win-' + win).style.display = 'flex'; 
            if(win==='explorer') loadSystemInfo(); 
            if(win==='db') loadDBTables(); 
            if(win==='rbac') loadRoles();
        }
        function closeWindow(win) { document.getElementById('win-' + win).style.display = 'none'; }

        async function loadRoles() {
            const res = await fetch(`/api/admin/roles/list?token=${token}`);
            const roles = await res.json();
            document.getElementById('roles-list').innerHTML = roles.map(r => `
                <button onclick="selectRoleForPerms(${r.id}, '${r.nombre}')" class="secondary" style="width:100%; text-align:left; ${window.selectedRoleId === r.id ? 'border-color:var(--primary); background:#e0e7ff;' : ''}">
                    ${r.nombre.toUpperCase()}
                </button>
            `).join('');
        }

        async function selectRoleForPerms(id, name) {
            window.selectedRoleId = id;
            document.getElementById('selected-role-name').textContent = name.toUpperCase();
            loadRoles(); // refrescar estilos
            
            const [allPermsRes, rolePermsRes] = await Promise.all([
                fetch(`/api/admin/permisos?token=${token}`),
                fetch(`/api/admin/roles/${id}/permisos?token=${token}`)
            ]);
            
            const allPerms = await allPermsRes.json();
            const rolePerms = await rolePermsRes.json();
            const rolePermIds = rolePerms.map(p => p.id);

            document.getElementById('permissions-grid').innerHTML = allPerms.map(p => `
                <div style="display:flex; align-items:center; gap:10px; background:#f8fafc; padding:10px; border-radius:8px; border:1px solid #e2e8f0;">
                    <input type="checkbox" ${rolePermIds.includes(p.id) ? 'checked' : ''} onchange="togglePermiso(${id}, ${p.id})">
                    <div>
                        <div style="font-weight:600; font-size:0.85rem;">${p.descripcion || 'Sin nombre'}</div>
                        <div style="font-size:0.7rem; color:#64748b;">${p.slug || 'sin-slug'}</div>
                    </div>
                </div>
            `).join('');
        }

        async function togglePermiso(roleId, permisoId) {
            await fetch(`/api/admin/roles/toggle-permiso?token=${token}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roleId, permisoId })
            });
            Swal.fire({ title: 'Permiso actualizado', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false, icon: 'success' });
        }

        async function createRole() {
            const nombre = document.getElementById('new-role-name').value;
            if(!nombre) return;
            const res = await fetch(`/api/admin/roles?token=${token}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ nombre })
            });
            if(res.ok) {
                document.getElementById('new-role-name').value = '';
                loadRoles();
            }
        }

        async function loadItems() {
            const res = await fetch(`/api/items?token=${token}`);
            const items = await res.json();
            document.getElementById('stat-total').textContent = items.length || 0;
            document.getElementById('stat-active').textContent = items.filter(i => i.estado).length || 0;
            document.getElementById('stat-inactive').textContent = items.filter(i => !i.estado).length || 0;
            document.getElementById('product-container').innerHTML = items.map(i => `
                <div class="product-card">
                    <b>${i.nombre || 'Sin nombre'}</b><p>${i.descripcion || 'Sin descripción'}</p><b>$${i.precio || '0.00'}</b><br>Stock: ${i.stock || 0}
                    <div style="margin-top:10px;">
                        ${role==='admin' ? 
                            `<button onclick='showModal(true, ${JSON.stringify(i)})' class="btn-small">Edit</button>
                             <button onclick='deleteItem(${i.id})' class="btn-small btn-danger">X</button>` : 
                            `<button onclick='buyItem(${i.id})' class="btn-small">Comprar</button>`
                        }
                    </div>
                </div>
            `).join('');
        }

        async function deleteItem(id) {
            if(!confirm('¿Eliminar producto?')) return;
            await fetch(`/api/items/${id}?token=${token}`, { method: 'DELETE' });
            loadItems();
        }

        async function buyItem(id) {
            const res = await fetch(`/api/shop/buy?token=${token}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId: id, cantidad: 1 })
            });
            const d = await res.json();
            Swal.fire(res.ok ? 'Éxito' : 'Error', d.message, res.ok ? 'success' : 'error');
            loadItems();
        }

        async function loadUsers() {
            const [usersRes, rolesRes] = await Promise.all([
                fetch(`/api/admin/users?token=${token}`),
                fetch(`/api/admin/roles/list?token=${token}`)
            ]);
            const users = await usersRes.json();
            const roles = await rolesRes.json();

            document.getElementById('users-table-body').innerHTML = users.map(u => `
                <tr>
                    <td data-label="Usuario"><b>${u.username}</b></td>
                    <td data-label="Email">${u.email}</td>
                    <td data-label="Nombre">${u.nombre || '-'}</td>
                    <td data-label="Rango">
                        <select onchange="updateUserRole(${u.id}, this.value)" style="padding:8px; border-radius:8px; width:100%;">
                            ${roles.map(r => `<option value="${r.nombre}" ${u.role === r.nombre ? 'selected' : ''}>${r.nombre.toUpperCase()}</option>`).join('')}
                        </select>
                    </td>
                    <td data-label="Acciones" style="text-align:right;">
                        <button onclick="kickUser(${u.id})" class="btn-small" title="Kick">🚫</button>
                        ${u.is_blocked ? `<button onclick="unblockUser(${u.id})" class="btn-small">🔓</button>` : ''}
                        <button onclick="deleteUser(${u.id})" class="btn-small btn-danger">🗑️</button>
                    </td>
                </tr>
            `).join('');
        }

        async function updateUserRole(userId, roleName) {
            const res = await fetch(`/api/admin/users/role?token=${token}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ userId, role: roleName })
            });
            if(res.ok) {
                Swal.fire({ title: 'Rol actualizado', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false, icon: 'success' });
            } else {
                const d = await res.json();
                Swal.fire('Error', d.message, 'error');
                loadUsers(); // Revertir visualmente
            }
        }

        async function kickUser(id) {
            const res = await fetch(`/api/admin/users/${id}/kick?token=${token}`, { method: 'POST' });
            Swal.fire('Usuario expulsado', '', 'success');
        }

        async function unblockUser(id) {
            const res = await fetch(`/api/admin/users/${id}/unblock?token=${token}`, { method: 'POST' });
            Swal.fire('Usuario desbloqueado', '', 'success');
            loadUsers();
        }

        async function deleteUser(id) {
            if(!confirm('¿Eliminar usuario definitivamente?')) return;
            const res = await fetch(`/api/admin/users/${id}?token=${token}`, { method: 'DELETE' });
            loadUsers();
        }

        async function refreshSystemStats() {
            const res = await fetch(`/api/system/stats?token=${token}`);
            const d = await res.json();
            document.getElementById('ram-usage').textContent = `${d.ram.used} / ${d.ram.total} GB`;
            document.getElementById('ram-bar').style.width = d.ram.percent + '%';
            document.getElementById('disk-usage').textContent = d.storage.used + ' / ' + d.storage.total;
            document.getElementById('disk-bar').style.width = d.storage.percent + '%';
        }

        async function loadDBTables() {
            const res = await fetch(`/api/system/db-tables?token=${token}`);
            const tables = await res.json();
            document.getElementById('db-tables-container').innerHTML = tables.map(t => `
                <div style="display:flex; justify-content:space-between; padding:10px; border-bottom:1px solid #eee;">
                    <span><b>${t.name}</b></span>
                    <span>${t.rows} filas</span>
                </div>
            `).join('');
        }

        async function loadSystemInfo(path = '.') {
            const res = await fetch(`/api/system/files?path=${encodeURIComponent(path)}&token=${token}`);
            const d = await res.json(); window.currentPath = d.currentPath;
            document.getElementById('file-explorer-body').innerHTML = d.files.map(f => `
                <tr><td>${f.isDirectory?'📁':'📄'} <span onclick="${f.isDirectory?`loadSystemInfo('${f.path.replace(/\\/g,'/')}')` : `openEditor('${f.path.replace(/\\/g,'/')}')`}" style="cursor:pointer;">${f.name}</span></td>
                <td>${!f.isDirectory?`<button onclick="openEditor('${f.path.replace(/\\/g,'/')}')">📝</button>`:''} <button onclick="deleteFileSystemItem('${f.path.replace(/\\/g,'/')}')">🗑️</button></td></tr>
            `).join('');
        }

        async function deleteFileSystemItem(path) {
            if(!confirm('¿Eliminar este archivo/carpeta?')) return;
            await fetch(`/api/system/file/delete?token=${token}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ path }) });
            loadSystemInfo(window.currentPath);
        }

        async function uploadFileToServer() {
            const fileInput = document.getElementById('file-upload-input');
            if(!fileInput.files[0]) return;
            const fd = new FormData(); fd.append('file', fileInput.files[0]);
            await fetch(`/api/system/file/upload?token=${token}`, { method: 'POST', body: fd });
            Swal.fire('Subido', '', 'success');
            loadSystemInfo(window.currentPath);
        }

        async function openEditor(path) {
            const res = await fetch(`/api/system/file/content?path=${encodeURIComponent(path)}&token=${token}`);
            const d = await res.json(); document.getElementById('editor-textarea').value = d.content;
            document.getElementById('editor-filename').textContent = path; window.currentEditPath = path;
            document.getElementById('editor-modal').style.display='flex';
        }
        function closeEditor() { document.getElementById('editor-modal').style.display='none'; }
        async function saveFileContent() {
            await fetch(`/api/system/file/save?token=${token}`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({path:window.currentEditPath, content:document.getElementById('editor-textarea').value}) });
            Swal.fire('Guardado','','success'); closeEditor();
        }

        async function executeTerminal() {
            const i = document.getElementById('terminal-input'); const cmd = i.value; if(!cmd) return;
            document.getElementById('terminal-output').innerHTML += `<br>$ ${cmd}`; i.value = '';
            const res = await fetch(`/api/system/terminal?token=${token}`, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({command:cmd}) });
            const d = await res.json(); document.getElementById('terminal-output').innerHTML += `<br>${(d.output||d.error||'OK').replace(/\n/g,'<br>')}`;
            document.getElementById('terminal-output').scrollTop = document.getElementById('terminal-output').scrollHeight;
        }

        async function showLogs() {
            const res = await fetch(`/api/system/logs?token=${token}`);
            const d = await res.json();
            Swal.fire({ title: 'Logs del Servidor', html: `<pre class="log-box">${d.logs}</pre>`, width: '800px' });
        }

        async function loadReports() {
            const res = await fetch(`/api/admin/reports/sales?token=${token}`);
            const d = await res.json();
            document.getElementById('rep-total-sales').textContent = d.length;
            document.getElementById('rep-total-earnings').textContent = '$' + d.reduce((a,b)=>a+parseFloat(b.precio),0).toFixed(2);
            document.getElementById('sales-report-body').innerHTML = d.map(s => `<tr><td>${s.cliente}</td><td>${s.producto}</td><td>$${s.precio}</td></tr>`).join('');
        }

        async function loadPurchases() {
            const res = await fetch(`/api/shop/my-purchases?token=${token}`);
            const d = await res.json();
            document.getElementById('purchases-table-body').innerHTML = d.map(p => `
                <tr style="border-bottom:1px solid var(--border);">
                    <td style="padding:15px;">
                        <div style="font-weight:600; color:var(--primary);">${p.nombre || 'Producto'}</div>
                        <div style="font-size:0.75rem; color:var(--text-gray);">${new Date(p.fecha).toLocaleString()}</div>
                    </td>
                    <td style="text-align:right; font-weight:700; font-size:1.1rem; padding:15px;">$${p.precio || '0.00'}</td>
                </tr>
            `).join('');
            if (d.length === 0) {
                document.getElementById('purchases-table-body').innerHTML = '<tr><td colspan="2" style="text-align:center; padding:2rem; color:var(--text-gray);">Aún no has realizado compras.</td></tr>';
            }
        }

        async function loadProfile() {
            try {
                const res = await fetch(`/api/auth/profile?token=${token}`);
                if (!res.ok) {
                    if (res.status === 401) logout();
                    throw new Error('Sesión no válida');
                }
                const u = await res.json();
                
                // Guardar permisos globalmente
                window.userPermissions = u.permissions || [];
                
                document.getElementById('p-email').value = u.email || ''; 
                document.getElementById('p-nombre').value = u.nombre || '';
                document.getElementById('user-name').textContent = u.nombre || u.username;
                document.getElementById('profile-username-title').textContent = u.username;
                
                const roleBadge = document.getElementById('user-role-badge');
                if (roleBadge) {
                    roleBadge.textContent = (u.role || 'User').toUpperCase();
                    roleBadge.className = 'badge ' + (u.role === 'admin' ? 'badge-active' : 'badge-danger');
                }
                
                if(u.foto) { 
                    document.getElementById('profile-img-preview').src = u.foto; 
                    document.getElementById('user-img-small').src = u.foto; 
                    document.getElementById('user-img-small').style.display='block'; 
                }

                // --- LÓGICA DE VISUALIZACIÓN POR PERMISOS ---
                const permMap = {
                    'nav-dashboard': 'admin:panel',
                    'nav-shop': 'item:view',
                    'nav-users': 'user:view',
                    'nav-system': 'admin:panel',
                    'nav-reports': 'admin:panel',
                    'btn-add-item': 'item:create'
                };

                Object.keys(permMap).forEach(id => {
                    const el = document.getElementById(id);
                    if (el) {
                        if (u.role === 'admin' || window.userPermissions.includes(permMap[id])) {
                            el.classList.remove('hidden');
                        } else {
                            el.classList.add('hidden');
                        }
                    }
                });

            } catch (e) {
                console.error('Error al cargar perfil:', e);
                Swal.fire('Error', 'No se pudo cargar tu perfil. Reintenta iniciando sesión.', 'error');
            }
        }

        async function updateProfile() {
            const fd = new FormData(); 
            fd.append('email', document.getElementById('p-email').value); 
            fd.append('nombre', document.getElementById('p-nombre').value);
            if(document.getElementById('p-foto').files[0]) fd.append('foto', document.getElementById('p-foto').files[0]);
            
            try {
                const res = await fetch(`/api/auth/profile?token=${token}`, { method:'PUT', body:fd }); 
                if (res.ok) {
                    Swal.fire('Perfil Actualizado','Se guardaron los cambios correctamente','success'); 
                    loadProfile();
                } else {
                    const d = await res.json();
                    Swal.fire('Error', d.message, 'error');
                }
            } catch (e) {
                Swal.fire('Error','No se pudo conectar con el servidor','error');
            }
        }

        async function restartServer() {
            const result = await Swal.fire({ 
                title: '¿Reiniciar Servidor?', 
                text: "El sistema estará fuera de línea unos segundos", 
                icon: 'warning', 
                showCancelButton: true, 
                confirmButtonText: 'Sí, reiniciar',
                confirmButtonColor: '#ef4444'
            });
            if (result.isConfirmed) {
                Swal.fire({ title: 'Reiniciando...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
                fetch(`/api/system/terminal?token=${token}`, { 
                    method:'POST', 
                    headers:{'Content-Type':'application/json'}, 
                    body:JSON.stringify({command:'pm2 restart all || npm restart'}) 
                });
                setTimeout(()=>window.location.reload(), 5000);
            }
        }

        function logout() { 
            localStorage.clear(); 
            window.location.href='/'; 
        }
        
        function showModal(s, item=null) { 
            window.editingId = item?item.id:null;
            document.getElementById('modal-title').textContent = item?'Editar Producto':'Nuevo Producto';
            document.getElementById('i-nombre').value = item?item.nombre:'';
            document.getElementById('i-precio').value = item?item.precio:'';
            document.getElementById('i-stock').value = item?item.stock:'';
            document.getElementById('i-desc').value = item?item.descripcion:'';
            document.getElementById('i-estado').value = item?item.estado.toString():'true';
            document.getElementById('item-modal').style.display = s?'flex':'none'; 
        }

        async function saveItem() {
            const body = { 
                nombre: document.getElementById('i-nombre').value, 
                precio: document.getElementById('i-precio').value, 
                stock: document.getElementById('i-stock').value, 
                descripcion: document.getElementById('i-desc').value, 
                estado: document.getElementById('i-estado').value==='true' 
            };
            
            try {
                const method = window.editingId?'PUT':'POST'; 
                const url = window.editingId?`/api/items/${window.editingId}?token=${token}`:`/api/items?token=${token}`;
                const res = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(body) });
                if (res.ok) {
                    showModal(false); 
                    loadItems();
                    Swal.fire({ title: '¡Guardado!', icon: 'success', toast: true, position: 'top-end', timer: 2000, showConfirmButton: false });
                } else {
                    const d = await res.json();
                    Swal.fire('Error', d.message, 'error');
                }
            } catch (e) {
                Swal.fire('Error de red', '', 'error');
            }
        }

        async function initApp() {
            await loadProfile();
            
            // Decidir vista inicial basado en permisos
            if (role === 'admin' || window.userPermissions.includes('admin:panel')) {
                toggleView('dashboard');
            } else {
                toggleView('shop');
            }
            
            // Refrescar stats si estamos en dashboard
            if (!document.getElementById('view-dashboard').classList.contains('hidden')) {
                loadItems();
            }
        }

        initApp();
    </script>
</body>
</html>
