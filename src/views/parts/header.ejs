<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pansilius Pro | Admin</title>
    <link rel="stylesheet" href="/menupanel.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* BOTONES PREMIUM (Como pediste) */
        .btn-add, .btn-primary { 
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%) !important;
            color: white !important; border: none !important; 
            padding: 0.8rem 1.5rem !important; border-radius: 14px !important;
            font-weight: 700 !important; cursor: pointer !important;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3) !important;
            transition: 0.3s !important;
        }
        .btn-add:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(79, 70, 229, 0.4); }

        .btn-delete {
            width: 34px; height: 34px; border-radius: 50%;
            background: #fee2e2; color: #ef4444; border: 1px solid #fecdd3;
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; cursor: pointer; transition: 0.2s;
        }
        .btn-delete:hover { background: #ef4444; color: white; transform: rotate(90deg); }

        .stat-card { border-radius: 24px; border: 1px solid #e2e8f0; background: white; padding: 2rem; }
        .hidden { display: none !important; }
        .wrapper { display: flex; min-height: 100vh; }
        .main-content { flex: 1; padding: 3rem; background: #f1f5f9; }
    </style>
</head>
<body>
    <div class="wrapper">
        <aside class="sidebar">
            <div class="logo">
                <div class="logo-box">P</div>
                <h2 style="color:white">Pansilius</h2>
            </div>
            <a href="/dashboard" class="nav-item">Dashboard</a>
            <a href="/users" class="nav-item">Usuarios</a>
            <a href="/system" class="nav-item">Servidor</a>
            <div style="margin-top: auto;">
                <div class="nav-item" onclick="logout()" style="color: #f87171;">Cerrar Sesión</div>
            </div>
        </aside>
        <main class="main-content">
